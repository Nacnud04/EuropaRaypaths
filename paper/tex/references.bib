@article{brothers_threedimensional_2016,
	title = {Three‐dimensional structure and origin of a 1.8 km thick ice dome within {Korolev} {Crater}, {Mars}},
	volume = {43},
	copyright = {http://onlinelibrary.wiley.com/termsAndConditions\#am},
	issn = {0094-8276, 1944-8007},
	url = {https://agupubs.onlinelibrary.wiley.com/doi/10.1002/2015GL066440},
	doi = {10.1002/2015GL066440},
	abstract = {Abstract
            
              Korolev is an 80 km diameter impact crater located at 72.7°N, 164.5°E containing a large domed deposit. Perennial water ice is thought to be currently unstable there; however, using a 3‐D analysis of the dome's internal radar stratigraphy, we estimate that Korolev's central mound contains between 1400 and 3500 km
              3
              of water ice that is up to 1.8 km thick. Furthermore, the stratigraphic structure of this ice dome is strikingly similar to the north polar layered deposits (NPLD) on Planum Boreum, approximately 600 km to the north. Additionally, our stratigraphic analysis suggests that Korolev ice was not previously part of a once larger polar ice sheet but rather it was deposited locally. We conclude that Korolev Crater's ice likely deposited during the same climate regime as Planum Boreum's NPLD, but independently. This implies that the incorporation of circumpolar ice deposits such as Korolev may prove useful in reconstructing a unique Mars polar climate history.
            
          , 
            Key Points
            
              
                
                  First 3‐D stratigraphy of a mounded ice deposit within an impact crater on Mars
                
                
                  Domal layering indicates localized, atmospheric deposition
                
                
                  Similarities to 600 km distant north polar layered deposits imply coeval deposition},
	language = {en},
	number = {4},
	urldate = {2026-02-24},
	journal = {Geophysical Research Letters},
	author = {Brothers, T. Charles and Holt, John W.},
	month = feb,
	year = {2016},
	pages = {1443--1449},
}

