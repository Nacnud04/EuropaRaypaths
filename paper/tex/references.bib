@inproceedings{byrne_high-resolution_2024,
	title = {High-{Resolution} {GPR} {Imaging} {Reveals} {Unmapped} {Cave} {Extent} at {Sulfur} {Cave}, {Steamboat} {Springs}, {CO}},
	volume = {2024},
	url = {https://ui.adsabs.harvard.edu/abs/2024AGUFMNS31A.116B},
	abstract = {Caves present unique hydrologic environments, acting as hosts for complex chemical and biological processes. Sulphur Cave in Steamboat Springs, Colorado, was formed by acidic spring water flowing into a large travertine deposit. This makes the cave unique as it represents both a rare form of speleogenesis as well as a host for extremophiles found nowhere else in the world. Therefore, to understand the extent of this rare environment and how it may evolve, it is crucial to map the cave's boundaries. In 2023, cavers mapped the cave extent, serving as a foundation for our research. In May 2024, as part of the 2024 Mines Geophysics Field Camp, we conducted a dual frequency ground penetrating radar (GPR) grid survey around the known cave area. We analyzed high-amplitude reflectors at depth that showed strong correlations with the cave map, suggesting the effectiveness of GPR mapping at both 50 and 100 MHz frequencies. We then interpreted additional high amplitude reflectors surrounding the mapped cave extent to assess whether there are additional regions of the cave. These regions align with the expected continuation of the cave passage based on hydrological flow directions and approximately double the cave area. Our results show that the cave is much larger than initially expected and likely continues beyond the extent of this study, suggesting additional work to expand the scope of investigations into the hydrologic and biotic environments of the many void spaces and caves in the near-surface environment beneath Steamboat Springs.},
	urldate = {2026-02-24},
	author = {Byrne, Duncan and Perkins, Jalen and Mazza, Luke and Bowling, Roy and Millstein, Joanna D. and Passerella, Brian and Dugan, Brandon and Siegfried, Matthew},
	month = dec,
	year = {2024},
	note = {ADS Bibcode: 2024AGUFMNS31A.116B},
	pages = {NS31A--116},
}

@inproceedings{byrne_radar_2024,
	title = {Radar {Altimetry} {Simulation} to {Identify} {Sub}-{Footprint} {Ice}-{Sheet} {Surface} {Change} at an {Antarctic} {Subglacial} {Lake}},
	volume = {2024},
	url = {https://ui.adsabs.harvard.edu/abs/2024AGUFMC33A.0399B},
	abstract = {Satellite radar altimetry signals from ice sheets represent scattering from both on- and off- nadir topography and the snow and firn volume. Deformation in the scattering surface at sub-footprint scales can dramatically influence the shape of the returned waveform. This influence enables the identification of sub-footprint deformation through alterations in the waveform shape. Here, we develop a new GPU enabled facet-based radar scattering model that can test hypotheses about surface deformation in the 30-year pulse-limited radar satellite altimetry record using arbitrary topographic input. We apply the scattering model to synthetic and real topographies demonstrating how different fixed and deforming surfaces influence the returned radar waveforms. Additionally, we assess the model's capability to identify sub-footprint surface evolution over subglacial lakes by deforming a high-resolution digital elevation model with estimated subglacial lake changes and compare the resulting modeled waveforms to on-orbit satellite radar altimetry data from the European Space Agency's Envisat radar altimeter. Because the simulator ingests arbitrary topography, it can be used to test hypotheses of sub-footprint topographic change indicative of dynamic ice-sheet processes on rough, high velocity ice streams and outlet glaciers in the decades prior to the existence of continuous (or quasi-continuous) laser altimetry or high resolution photogrammetric models capable of observing such features. In doing so, we can better constrain ice dynamic processes occurring at finer spatial scales across longer time scales.},
	urldate = {2026-02-24},
	author = {Byrne, Duncan and Klemm, Jared and Siegfried, Matthew and Castelletti, Davide and Michaelides, Roger J. and Schroeder, Dustin M.},
	month = dec,
	year = {2024},
	note = {ADS Bibcode: 2024AGUFMC33A.0399B},
	pages = {C33A--0399},
}

@inproceedings{verboncoeur_multidecadal_2023,
	title = {Multidecadal signals of dynamic thickness change in the {Crary} {Ice} {Rise} region driven by century-scale reorganization of the southern {Ross} {Sea} sector ice streams},
	volume = {2023},
	url = {https://ui.adsabs.harvard.edu/abs/2023AGUFM.C11A..08V},
	abstract = {Subglacial topographic features that locally stabilize ice-shelf flow, known as pinning points, contribute significantly to the buttressing of the grounded ice sheet. As the ice flux from grounded ice streams and outlet glaciers evolves, so do the local grounding zones of downstream pinning points, introducing poorly resolved feedbacks to highly dynamic ice systems. The century-scale reorganization of ice streams along the Gould, Siple, and Shirase coasts of the West Antarctic Ice Sheet (WAIS) provides an opportunity to investigate how upstream thickness changes interact with pinning point processes on decadal timescales as these ice streams flow into major Ross Ice Shelf pinning points. Here, we construct and analyze a 20-year multi-mission satellite altimetry record of dynamic ice thickness change (dh/dt) in the region surrounding Crary Ice Rise, one of the largest pinning points of the largest ice shelf in Antarctica. We use data from the Ice, Cloud, and land Elevation Satellite (ICESat; 2003-2009), CryoSat-2 (2010-present), and ICESat-2 (2018-present) satellite altimetry missions to identify localized, persistent patterns of surface elevation change on the lower Whillans Ice Plain. Our results suggest that both grounding zone migration and flow redirection around Crary Ice Rise are influenced by the on-going slowdown and subsequent thickening of Whillans Ice Stream. Regions upstream of Crary Ice Rise that thinned during the ICESat period generally evolve to thickening by the end of the study period. We investigate the impact of this transition on the buttressing capability of Crary Ice Rise through surface elevation anomalies to quantify the on-going co-evolution of ice stream dynamics and pinning point processes.},
	urldate = {2026-02-24},
	author = {Verboncoeur, Hannah and Siegfried, Matthew and Winberry, Jeremy Paul and Holschuh, Nicholas and Byrne, Duncan and Sauthoff, Wilson and Sutterley, Tyler C. and Medley, Brooke},
	month = dec,
	year = {2023},
	note = {ADS Bibcode: 2023AGUFM.C11A..08V},
	pages = {C11A--08},
}

